---
import { Moon, Sun, TvMinimal } from "@lucide/astro";
---

<div class="absolute right-4 top-4 z-40 md:right-6 md:top-6">
	<div class="theme-toggle theme-toggle-panel">
		<button
			type="button"
			class="theme-toggle-btn theme-toggle-button"
			aria-label="Theme toggle"
			title="Theme"
		>
			<span data-theme-icon="light"><Sun size={16} /></span>
			<span data-theme-icon="dark" hidden><Moon size={16} /></span>
			<span data-theme-icon="system" hidden><TvMinimal size={16} /></span>
		</button>
	</div>
</div>

<script is:inline data-astro-rerun>
	(() => {
		window.__theme?.init?.();
	})();
</script>
