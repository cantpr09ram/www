---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";
import BaseBody from "./BaseBody.astro";
import type { SeriesContext } from "../lib/series";

type Props = CollectionEntry<"blog">["data"] & {
	slug: string;
	seriesContext?: SeriesContext;
};
const { title, description, pubDate, updatedDate, slug, seriesContext } =
	Astro.props;
const titleTransitionName = `post-title-${slug.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={`/og/${slug}.png`} />
  </head>

  <BaseBody showHeader showFooter>
        <article>
          <div class="article-frame">
            <div class="article-header">
              <h1
                class="article-title"
                transition:name={titleTransitionName}
              >
                {title}
              </h1>
              {
                seriesContext && (
                  <p class="mb-2 text-app-text-muted">
                    <a
                      href={`/blog/?series=${seriesContext.series.slug}`}
                      class="content-link font-medium text-app-text"
                    >
                      {seriesContext.series.title}
                    </a>
                  </p>
                )
              }
              <div class="mb-2 text-xs text-app-text-muted">
                <FormattedDate date={pubDate} />
                {
                  updatedDate && (
                    <div class="italic">
                      Last updated on <FormattedDate date={updatedDate} />
                    </div>
                  )
                }
              </div>
              <hr class="border-gray-200 dark:border-gray-800" />
            </div>
            <div class="prose max-w-none dark:prose-invert">
              <slot />
            </div>
          </div>
        </article>
  </BaseBody>
</html>
