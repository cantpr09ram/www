---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ThemeToggle from "../components/ThemeToggle.astro";

interface Props {
	bodyClass?: string;
	shellClass?: string;
	mainClass?: string;
	showHeader?: boolean;
	showFooter?: boolean;
}

const {
	bodyClass = "ds-body",
	shellClass = "page-shell",
	mainClass = "page-main",
	showHeader = false,
	showFooter = false,
} = Astro.props;
---

<body class={bodyClass}>
	<ThemeToggle />
	<div class={shellClass}>
		<main class={mainClass}>
			{showHeader && <Header />}
			<slot />
			{showFooter && <Footer />}
		</main>
	</div>
</body>
