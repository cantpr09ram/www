---
import { getEntry, render } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import BaseBody from "../layouts/BaseBody.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
const me = await getEntry("pages", "me");

if (!me) {
	throw new Error("Missing src/content/pages/me.mdx");
}

const { Content } = await render(me);
const title = me.data.title ?? SITE_TITLE;
const description = me.data.description ?? SITE_DESCRIPTION;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<BaseBody
		bodyClass="ds-body"
		shellClass="home-shell"
		mainClass="home-main"
		showFooter
	>
		<section class="home-content">
			<div class="pl-3 pb-2 space-y-5">
				<div class="prose max-w-none">
					<Content />
				</div>
			</div>
		</section>
	</BaseBody>
</html>
