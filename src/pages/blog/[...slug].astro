---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import { getSeriesContext } from "../../lib/series";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.id },
		props: {
			post,
			seriesContext: getSeriesContext(posts, post.id),
		},
	}));
}
type Props = {
	post: CollectionEntry<"blog">;
	seriesContext?: ReturnType<typeof getSeriesContext>;
};

const { post, seriesContext } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} slug={post.id} seriesContext={seriesContext}>
	<Content />
</BlogPost>
