---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseBody from "../../layouts/BaseBody.astro";
import { getAllSeries } from "../../lib/series";

const posts = (
	await getCollection("blog", ({ data }) => data.isdrift !== true)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const series = getAllSeries(posts);
const getPostTransitionName = (id: string) =>
	`post-title-${id.replace(/[^a-zA-Z0-9_-]/g, "-")}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<BaseBody showHeader showFooter>
			<section class="page-section">
				{
					series.map((item) => (
						<h1
							class="mb-4 text-2xl font-semibold text-app-heading"
							data-series-title={item.slug}
							hidden
						>
							{item.title}
						</h1>
					))
				}
				<ul class="blog-list" data-post-list="all">
					{
					posts.map((post) => (
						<li data-series-slug={post.data.series?.slug ?? ""}>
							<div class="post-row">
								<div class="post-title">
									<a
										href={`/blog/${post.id}/`}
										class="content-link text-sm md:text-base"
										transition:name={getPostTransitionName(post.id)}
									>
										{post.data.title}
									</a>
								</div>
								<p class="post-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</div>
						</li>
					))
					}
				</ul>
				{
					series.map((item) => (
						<ul
							class="blog-list"
							data-post-list={item.slug}
							hidden
						>
							{item.posts.map((post) => (
								<li>
									<div class="post-row">
										<div class="post-title">
											<a
												href={`/blog/${post.id}/`}
												class="content-link"
											>
												{post.data.title}
											</a>
										</div>
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
									</div>
								</li>
							))}
						</ul>
					))
				}
				<p class="text-sm text-app-text-muted" data-empty-series hidden>
					No posts in this series.
				</p>
			</section>
	<script is:inline>
		const applySeriesFilter = () => {
			const params = new URLSearchParams(window.location.search);
			const selectedSeries = params.get("series") || "all";
			const lists = Array.from(document.querySelectorAll("[data-post-list]"));
			const filters = Array.from(document.querySelectorAll("[data-series-filter]"));
			const titles = Array.from(document.querySelectorAll("[data-series-title]"));
			const emptyState = document.querySelector("[data-empty-series]");
			let hasVisibleList = false;

			for (const list of lists) {
				const isVisible = list.dataset.postList === selectedSeries;
				list.hidden = !isVisible;
				hasVisibleList ||= isVisible;
			}

			for (const filter of filters) {
				const isActive = filter.dataset.seriesFilter === selectedSeries;
				if (isActive) {
					filter.setAttribute("aria-current", "page");
				} else {
					filter.removeAttribute("aria-current");
				}
				filter.classList.toggle("text-app-text", isActive);
				filter.classList.toggle("font-medium", isActive);
			}

			for (const title of titles) {
				title.hidden = title.dataset.seriesTitle !== selectedSeries;
			}

			if (emptyState) {
				emptyState.hidden = hasVisibleList;
			}
		};

		document.addEventListener("astro:page-load", applySeriesFilter);
		applySeriesFilter();
	</script>
	</BaseBody>
</html>
