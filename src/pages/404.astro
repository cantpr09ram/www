---
import BaseHead from "../components/BaseHead.astro";
import EarthGlobe from "../components/EarthGlobe";
import BaseBody from "../layouts/BaseBody.astro";

const markers = [
	{ id: "taiwan", label: "TAIWAN", location: [25.033, 121.5654], size: 0.03 },
	//{ id: "nyc", label: "New York", location: [40.7128, -74.006], size: 0.03 },
	//{ id: "london", label: "London", location: [51.5072, -0.1276], size: 0.03 },
];

const globeConfig = {
	rotationSpeed: 0.0,
	mapBrightness: 5,
	initialLocation: [23.6978, 120.9605] as [number, number],
};
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="404" description="Page not found" />
	</head>
	<BaseBody
		bodyClass="ds-body max-w-main mx-4 mt-8 lg:mx-auto bg-app-surface text-app-text"
		shellClass=""
		mainClass="flex-auto min-w-0 mt-6 flex flex-col px-2 md:px-0"
	>
		<section class="mx-auto flex min-h-[84vh] w-full max-w-3xl flex-col items-center justify-center text-center">
			<EarthGlobe
				client:load
				markers={markers}
				rotationSpeed={globeConfig.rotationSpeed}
				mapBrightness={globeConfig.mapBrightness}
				initialLocation={globeConfig.initialLocation}
			/>
			<p>Hello from <a class="muted-link" href="https://en.wikipedia.org/wiki/Taiwan">Taiwan</a></p>
			<a class="muted-link" href="/">GO BACK</a>

		</section>
	</BaseBody>
</html>
